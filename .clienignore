# ==============================================================================
# 1. 业务与非必要文档屏蔽 (根据你的要求补充)
# ==============================================================================
# 彻底屏蔽 docs 下不需要的 business 文件夹及其子目录
docs/business/

# ==============================================================================
# 2. 前端及 Monorepo 依赖屏蔽 (防止重度扫描)
# ==============================================================================
node_modules/
.pnpm-store/
apps/**/node_modules/

# ==============================================================================
# 3. Next.js & 构建产物屏蔽 (针对 apps/web 结构补充)
# ==============================================================================
# Next.js 本地开发和构建缓存（这个极其庞大，经常包含数万行编译后的 JS 碎片）
.next/
apps/web/.next/

# 常规打包输出
dist/
build/

# ==============================================================================
# 4. 测试框架及缓存屏蔽 (针对 vitest, playwright 补充)
# ==============================================================================
# Vitest 单元测试覆盖率报告与缓存
coverage/
.vitest-cache/
apps/web/coverage/
apps/web/.vitest-cache/

# Playwright 端到端测试产生的报告、截图、视频和跟踪文件
playwright-report/
test-results/
apps/web/playwright-report/
apps/web/test-results/

# ==============================================================================
# 5. 数据库与本地环境变量隔离 (针对 supabase, drizzle, env 补充)
# ==============================================================================
# 本地环境变量，包含你的各种秘钥和 Supabase URL，防泄露
.env
.env.local
.env.development
.env.production
apps/web/.env
apps/web/.env.*

# 隐藏的版本控制文件
.git/
.github/
.vscode/